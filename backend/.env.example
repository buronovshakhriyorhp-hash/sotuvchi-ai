# Nexus ERP - Backend Environment Variables
# Ushbu fayldan nusxa olib, backend/.env deb nomlang va qiymatlarni to'ldiring.

# Server sozlamalari
PORT=5000
NODE_ENV=production  # production yoki development

# Xavfsizlik (Ushbu kalitni juda murakkab qilib tanlang!)
# Masalan: openssl rand -base64 32
JWT_SECRET=o_z_maxfiy_kalitingizni_bu_yerga_yozing_2026

# Ma'lumotlar bazasi
DATABASE_URL=postgresql://username:password@localhost:5432/database_name?schema=public

# Redis cache (ixtiyoriy, lekin tavsiya etiladi)
REDIS_URL=redis://localhost:6379

# Admin paroli (ixtiyoriy, default: Sotuvchi2024!Secure@Admin)
ADMIN_PASSWORD=o_z_admin_parolingiz

# Telegram bot (ixtiyoriy)
TELEGRAM_BOT_TOKEN=bot_token

# HTTPS qo'llab-quvvatlash
FORCE_HTTPS=false

# Monitoring / Metrics
# Agar true bo'lsa, /metrics endpointi ochiladi
ENABLE_METRICS=true
