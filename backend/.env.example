# Nexus ERP - Backend Environment Variables
# Ushbu fayldan nusxa olib, backend/.env deb nomlang va qiymatlarni to'ldiring.

# Server sozlamalari
PORT=5000
NODE_ENV=production  # production yoki development

# ═══════════════════════════════════════════════
# XAVFSIZLIK (Muhim! Kuchli va tasodifiy qiymat kiriting!)
# ═══════════════════════════════════════════════

# JWT Secret — kamida 64 bayt random string
# Yaratish: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
JWT_SECRET=

# Ma'lumotlar bazasi
DATABASE_URL=postgresql://username:password@localhost:5432/database_name?schema=public

# Redis cache (ixtiyoriy, lekin tavsiya etiladi)
REDIS_URL=redis://localhost:6379

# ═══════════════════════════════════════════════
# PAROLLAR (Seed uchun — production'da ham kuchli bo'lishi SHART)
# ═══════════════════════════════════════════════
SUPER_ADMIN_PASSWORD=
ADMIN_SEED_PASSWORD=
CASHIER_SEED_PASSWORD=

# Telegram bot tokenlari (BotFather dan oling)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CLIENT_BOT_TOKEN=
SUPERADMIN_BOT_TOKEN=
ROOT_ADMIN_ID=

# HTTPS qo'llab-quvvatlash
FORCE_HTTPS=false

# Monitoring / Metrics
# /metrics endpointi faqat ADMIN/SUPERADMIN uchun ochiq
ENABLE_METRICS=true

# Frontend URL (CORS uchun — production'da majburiy)
FRONTEND_URL=https://your-domain.com
