# Nexus ERP - Backend Environment Variables
# Ushbu fayldan nusxa olib, backend/.env deb nomlang va qiymatlarni to'ldiring.

# Server sozlamalari
PORT=5000
NODE_ENV=production  # production yoki development

# Xavfsizlik (Ushbu kalitni juda murakkab qilib tanlang!)
# Masalan: openssl rand -base64 32
JWT_SECRET=o_z_maxfiy_kalitingizni_bu_yerga_yozing_2026

# Ma'lumotlar Bazasi (PostgreSQL)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# Masalan: postgresql://nexus_user:secret_pass@localhost:5432/nexus_db?schema=public
DATABASE_URL="postgresql://user:password@localhost:5432/db_name?schema=public"

# Ruxsat berilgan domenlar (CORS) - vergul bilan ajrating
# Agar domain bo'lmasa, "*" yoki localhost va IP manzilingizni yozing
ALLOWED_ORIGINS="http://localhost:5173,http://your-ip-address:5173"

# Telegram Bot
TELEGRAM_BOT_TOKEN="sizning_bot_tokeningiz"
