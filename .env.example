# ═══════════════════════════════════════════════════════
# Nexus ERP — Production Environment Variables
# ═══════════════════════════════════════════════════════
# Bu faylni .env ga nusxalang va qiymatlarni to'ldiring:
#   cp .env.example .env
# ═══════════════════════════════════════════════════════

# ── Frontend ──
VITE_API_BASE_URL=/api
FRONTEND_URL=https://your-domain.uz

# ── PostgreSQL Database ──
POSTGRES_USER=sotuvchi_admin
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
POSTGRES_DB=sotuvchi_ai

# ── Security ──
# JWT Secret — kamida 256-bit random string:
#   node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
JWT_SECRET=CHANGE_ME_GENERATE_WITH_COMMAND_ABOVE

# ── Telegram Bot Tokenlari ──
# @BotFather dan olingan tokenlar
TELEGRAM_BOT_TOKEN=your_bot_token_here
SUPERADMIN_BOT_TOKEN=your_superadmin_bot_token_here

# ── Seed Parollar (Ixtiyoriy) ──
# Agar o'rnatilmasa, kuchli default ishlatiladi
# SUPER_ADMIN_PASSWORD=your_super_admin_password
# ADMIN_SEED_PASSWORD=your_admin_password
# CASHIER_SEED_PASSWORD=your_cashier_password
